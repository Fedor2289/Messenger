# ─── ОБЯЗАТЕЛЬНО НАСТРОИТЬ ────────────────────────────────────────────────
# PostgreSQL URL (Railway создаёт автоматически при добавлении PostgreSQL сервиса)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секретный ключ JWT — замените на случайную строку длиной 32+ символа
JWT_SECRET=измените-это-на-случайную-строку-32-символа

# ─── НЕОБЯЗАТЕЛЬНО ────────────────────────────────────────────────────────
# Порт (Railway устанавливает автоматически)
PORT=3000
