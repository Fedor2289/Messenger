# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Секретный ключ для JWT — сгенерируй случайный!
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа

# База данных (оставь пустым для SQLite локально)
# На Railway это подставляется автоматически при добавлении PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
